# DUQ Safety Service - Environment Variables

# Server Configuration
SAFETY_HOST=0.0.0.0
SAFETY_PORT=8083
LOG_LEVEL=INFO

# LLM Configuration (for complex safety checks)
# At least one API key is required for LLM fallback
ANTHROPIC_API_KEY=sk-ant-...
OPENROUTER_API_KEY=sk-or-...

# LLM Provider Settings
LLM_DEFAULT_PROVIDER=anthropic  # anthropic or openrouter
LLM_SAFETY_MODEL=claude-haiku-4-5-20251001
USE_LLM_FALLBACK=true  # Enable LLM for unmatched rules

# Alerting (optional)
ALERT_WEBHOOK_URL=https://hooks.slack.com/services/...
OWNER_TELEGRAM_ID=123456789
